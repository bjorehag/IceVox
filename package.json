{
  "name": "icevox",
  "version": "0.3.0",
  "description": "Real-time voice effects and P2P voice chat for gaming and roleplay",
  "main": "src/main.js",
  "author": "Bjorehag",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "set ELECTRON_ENABLE_LOGGING=1 && electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.icevox.app",
    "productName": "IceVox",
    "copyright": "Copyright © 2025 Bjorehag",

    "directories": {
      "output": "dist",
      "buildResources": "build"
    },

    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],

    "asar": true,
    "asarUnpack": [
      "**/audio-worklet-processor.js"
    ],

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },

    "nsis": {
      "artifactName": "IceVox-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IceVox",
      "perMachine": false,
      "allowElevation": true
    },

    "protocols": [
      {
        "name": "IceVox Protocol",
        "schemes": ["icevox"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "peerjs": "^1.5.5"
  }
}
